  {
    "abstract_id": "76MO",
    "trial_name": "PICCOLO",
    "source_family": "ESMO",
    "meeting_name": "ESMO Gynaecological Cancers Congress",
    "year": 2025,
    "presentation_type": "Mini oral presentation",
    "disease": "platinum-sensitive recurrent ovarian cancer",
    "population": "Patients with FRα-positive, third-line or later platinum-sensitive ovarian cancer",
    "intervention": "Mirvetuximab soravtansine-gynx",
    "comparator": null,
    "endpoint": "Objective response rate, progression-free survival and overall survival",
    "result_summary": "The final analysis of the single-arm phase II PICCOLO trial showed that mirvetuximab soravtansine-gynx produced durable responses in heavily pretreated, FRα-positive platinum-sensitive ovarian cancer.\nMedian PFS was 6.93 months (95% CI 5.85–9.59) and median OS was 27.17 months (95% CI 23.79–not reached). The objective response rate was 51.9%, and the median duration of response was 8.25 months. In the\nPARP-inhibitor–naïve cohort, ORR reached 75% with a median PFS of 10.02 months and median OS of 27.89 months; in PARP-inhibitor–exposed patients, ORR was 46.9% with median PFS 6.87 months and OS 27.17 months.",
    "result_metrics": {
      "objective_response_rate": 0.519,
      "median_PFS_months_intervention": 6.93,
      "median_OS_months_intervention": 27.17,
      "median_DOR_months": 8.25,
      "objective_response_rate_PARPi_naive": 0.75,
      "median_PFS_PARPi_naive": 10.02,
      "median_OS_PARPi_naive": 27.89,
      "objective_response_rate_PARPi_exposed": 0.469,
      "median_PFS_PARPi_exposed": 6.87,
      "median_OS_PARPi_exposed": 27.17
    },
    "nct_id": "NCT05041257"
